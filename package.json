    "preview": "vite preview --host 0.0.0.0 --port 4173 --strictPort"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@tauri-apps/api": "^2.11.0",
    "clsx": "^2.1.1",
