{
  "name": "agent-control",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420 --strictPort",
    "dev:desktop": "tauri dev",
    "build": "tsc -b && vite build",
    "build:desktop": "tauri build && pnpm sync:desktop-app",
    "sync:desktop-app": "./scripts/sync-desktop-app.sh",
    "check:native": "cargo check --manifest-path src-tauri/Cargo.toml",
